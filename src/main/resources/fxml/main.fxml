<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootNode" prefHeight="600.0" prefWidth="900.0" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.app.extractor.ui.MainController">
    
    <!-- Верхня панель: Керування файлами конфігурації -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
            <Button text="📂 Відкрити" onAction="#handleOpenConfig"/>
            <Button text="💾 Зберегти як..." onAction="#handleSaveConfig"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="themeBtn" text="🌓 Тема" onAction="#handleToggleTheme"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.3">
            <!-- Ліва панель: Список збережених пресетів -->
            <VBox spacing="10" maxWidth="300">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="ЗБЕРЕЖЕНІ ПРЕСЕТИ" style="-fx-font-weight: bold;"/>
                <ListView fx:id="presetListView" VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- Центральна панель: Параметри поточної обробки -->
            <VBox spacing="15">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                
                <VBox spacing="5" style="-fx-background-color: #fafafa; -fx-padding: 10; -fx-border-color: #ddd;">
                    <Label text="ДЖЕРЕЛО ДАНИХ (Папка з PDF/DOCX)"/>
                    <HBox spacing="10">
                        <TextField fx:id="sourcePathField" HBox.hgrow="ALWAYS" editable="false"/>
                        <Button text="📂" onAction="#handleSelectSource"/>
                    </HBox>
                    <Label text="ВИХІДНИЙ ФАЙЛ (.xlsx)"/>
                    <HBox spacing="10">
                        <TextField fx:id="outputPathField" HBox.hgrow="ALWAYS" editable="false"/>
                        <Button text="📂" onAction="#handleSelectOutput"/>
                    </HBox>
                </VBox>

                <Label text="НАБОРИ ДАНИХ (Конфігурація полів)" style="-fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox fx:id="fieldsContainer" spacing="10">
                        <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
                    </VBox>
                </ScrollPane>
                
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="➕ Додати набір даних" onAction="#handleAddRow"/>
                    <Button text="▶️ ЗАПУСТИТИ ОБРОБКУ" onAction="#handleRun" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>